STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# LLM 코칭 코멘트 provider: "github"(GPT-4o) 또는 "anthropic"
LLM_PROVIDER=github
# GitHub Models용 PAT (https://github.com/settings/tokens, scope: models:read)
GITHUB_TOKEN=
# provider=anthropic 일 때만 필요
ANTHROPIC_API_KEY=

# 목표·AI계획을 GitHub state 브랜치에 저장(HF 재시작 보존)용 PAT.
# scope: repo (classic) 또는 contents:write (fine-grained). 없으면 GITHUB_TOKEN 사용.
GITHUB_STATE_TOKEN=
# (선택) 저장 위치 재정의 — 기본값이면 생략 가능
# STATE_REPO=SangjunPark54/StravaCoach
# STATE_BRANCH=state

# (선택) 날씨 예보 위치 — 기본 서울. AI 코치가 강수 예보로 비 안 오는 날에 야외 세션 배치.
# 별도 API 키 불필요(Open-Meteo).
# WEATHER_LAT=37.5665
# WEATHER_LON=126.9780
# WEATHER_LABEL=서울
